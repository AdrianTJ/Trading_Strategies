{
  "name": "strategy-tracker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start:backend": "uvicorn src.api.main:app --reload",
    "start:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "test:backend": "PYTHONPATH=. pytest",
    "test:frontend": "npm run test --prefix frontend",
    "test": "npm run test:backend",
    "sync": "python scripts/sync_data.py && python scripts/align_data.py && python scripts/run_simulations.py",
    "clear-results": "python scripts/clear_results.py"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
